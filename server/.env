# Database Configuration (UPDATE THESE WITH YOUR ACTUAL DATABASE DETAILS)
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=GenVolt_dev
DB_USER=genvolt
DB_PASSWORD=genvolt@123
DB_TRUST_SERVER_CERTIFICATE=true
DB_ENCRYPT=true
DB_REQUEST_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=15000
DB_POOL_MIN=5
DB_POOL_MAX=20

# JWT Configuration (THESE ARE TEMPORARY - CHANGE IN PRODUCTION)
JWT_SECRET=this_is_a_very_secure_secret_key_change_in_production_at_least_32_characters_long
JWT_REFRESH_SECRET=this_is_a_very_secure_refresh_secret_key_change_in_production_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration
PORT=5001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3008

# Rate Limiting (Increased for development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=debug

# Security
BCRYPT_ROUNDS=12

# Application Settings
APP_NAME=GenVolt IoT Dashboard API
APP_VERSION=1.0.0