# Copy to .env in the same directory as local_subscriber.py

# MQTT Broker (localhost when running on the VM)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=local_subscriber
MQTT_PASSWORD=ghost@123
PRE_ACTIVATION_SECRET=dev-secret-123

# Optional — enables session kick during activation. Without it, a warning is
# logged and activation proceeds normally (fine for local testing).

# Azure SQL
DB_SERVER=localhost
DB_DATABASE=cs_db_dev
DB_USER=sa
DB_PASSWORD=ghost@123
